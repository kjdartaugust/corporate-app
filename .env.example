# Supabase — copy to .env.local and fill in from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server only, used by the seed script. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Set to "true" to run the app with built-in demo data and no Supabase connection.
NEXT_PUBLIC_DEMO_MODE=true
